// Supabase Configuration — copy to Supabase.xcconfig and fill in real values
// Supabase.xcconfig is gitignored — never commit actual keys
// xcconfig treats // as a comment. Use /$()/  to embed // in URL values.
SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
SUPABASE_REDIRECT_URL = com.proof.capture:/$()/auth-callback
